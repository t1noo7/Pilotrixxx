# ============================================================
# Copy file nay thanh .env va dien gia tri thuc te.
# KHONG commit file .env len git (da co trong .gitignore)
# ============================================================

# --- Server ---
PORT=3000

# --- Postgres (Supabase Transaction Pooler) ---
# Lay tu: Supabase Dashboard -> Connect -> Transaction pooler
# Nho URL-encode ky tu dac biet trong password (vd @ -> %40)
DATABASE_URL=postgresql://postgres.xxxxx:YOUR_PASSWORD@aws-x-xx-southeast-x.pooler.supabase.com:6543/postgres

# --- MQTT (HiveMQ Cloud) ---
MQTT_HOST=8d8312a036d34ad884a1639b5f7894bf.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USERNAME=datn-backend
MQTT_PASSWORD=YOUR_MQTT_PASSWORD